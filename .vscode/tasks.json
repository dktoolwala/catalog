{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ng serve",
      "type": "shell",
      "command": "npx ng serve",
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"]
    },
    {
      "label": "ng build",
      "type": "shell",
      "command": "npx ng build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "ng build (production)",
      "type": "shell",
      "command": "npx ng build --configuration=production",
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "ng test",
      "type": "shell",
      "command": "npx ng test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "ng test (CI)",
      "type": "shell",
      "command": "npx ng test --no-watch --code-coverage",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "npx ng lint",
      "group": "build",
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "lint:fix",
      "type": "shell",
      "command": "npx ng lint --fix",
      "group": "build",
      "problemMatcher": ["$eslint-stylish"]
    }
  ]
}
